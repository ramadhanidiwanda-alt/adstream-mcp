{
  "name": "adstream-mcp",
  "version": "0.6.0",
  "description": "Open-source MCP connector hub for ads and commerce analytics, powered by Cuan Insight credentials.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "adstream-mcp": "dist/mcp/index.js",
    "meta-ads-mcp": "dist/mcp/index.js"
  },
  "type": "module",
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "example:daily-report": "tsx examples/daily-report.ts",
    "example:campaign-audit": "tsx examples/campaign-audit.ts",
    "example:rule-engine": "tsx examples/rule-engine-demo.ts",
    "example:rule-templates": "tsx examples/rule-templates-demo.ts",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test:local-meta-breakdown": "tsx --env-file=.env scripts/testLocalMetaBreakdown.ts"
  },
  "keywords": [
    "meta-ads",
    "adstream",
    "cuan-insight",
    "ads-mcp",
    "facebook-ads",
    "instagram-ads",
    "marketing-api",
    "ai-agent",
    "ai-skills",
    "insights",
    "rule-engine",
    "campaign-analysis",
    "performance-monitoring",
    "codex",
    "mcp",
    "claude",
    "typescript",
    "approval-workflow"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ramadhanidiwanda-alt/adstream-mcp.git"
  },
  "files": [
    "dist",
    "skills",
    ".mcp.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "dotenv-safe": "^9.1.0",
    "eslint": "^9.2.0",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "tsx": "^4.9.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.8"
  }
}
