{
  "name": "meta-ads-agent-skill",
  "version": "0.3.0",
  "description": "TypeScript library + AI skills for Meta Ads analysis. Built for developers and end users.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "example:daily-report": "tsx examples/daily-report.ts",
    "example:campaign-audit": "tsx examples/campaign-audit.ts",
    "example:rule-engine": "tsx examples/rule-engine-demo.ts",
    "example:rule-templates": "tsx examples/rule-templates-demo.ts",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "keywords": [
    "meta-ads",
    "facebook-ads",
    "instagram-ads",
    "marketing-api",
    "ai-agent",
    "ai-skills",
    "insights",
    "rule-engine",
    "campaign-analysis",
    "performance-monitoring",
    "codex",
    "mcp",
    "claude",
    "typescript",
    "read-only"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ramadhanidiwanda-alt/meta-ads-agent-skill.git"
  },
  "files": [
    "dist",
    "mcp-server/dist",
    "skills",
    ".mcp.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "dotenv": "^16.4.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "dotenv-safe": "^9.1.0",
    "eslint": "^9.2.0",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "tsx": "^4.9.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "workspaces": [
    "mcp-server"
  ]
}
