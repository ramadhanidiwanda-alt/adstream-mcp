# =============================================================================
# Self-Hosted Environment — Copy to .env.selfhosted and fill your tokens
# =============================================================================
# This setup runs adstream-mcp in local mode with direct provider tokens.
# No Cuan Insight account required.
# =============================================================================

NODE_ENV=production
MCP_TRANSPORT=streamable-http
MCP_HTTP_ENABLED=true
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8000
BROKER_RUNTIME_MODE=local
ADSTREAM_ENABLE_WRITES=true

# --- Provider Tokens ---
# Get your Meta Access Token from: https://developers.facebook.com/tools/access_token/
META_ACCESS_TOKEN=<your-meta-access-token>
META_AD_ACCOUNT_ID=<your-meta-ad-account-id>

# TikTok token (optional)
TIKTOK_ACCESS_TOKEN=

# --- OAuth (optional for local mode) ---
MCP_PUBLIC_BASE_URL=http://127.0.0.1:8000
