# =============================================================================
# meta-ads-agent-skill — Environment Configuration
# =============================================================================
# Copy to .env and fill in values for your deployment.
# Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Runtime / Transport
# -----------------------------------------------------------------------------
NODE_ENV=production

# stdio | sse | streamable-http
# stdio: local MCP client (default)
# streamable-http: hosted remote MCP server
MCP_TRANSPORT=stdio

# Used for sse / streamable-http
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8000

# -----------------------------------------------------------------------------
# 2. Broker Runtime Mode
# -----------------------------------------------------------------------------
# remote: resolve credentials via Cuan Insight credential control plane
# local: use direct provider tokens from environment (Section 7)
BROKER_RUNTIME_MODE=remote

# -----------------------------------------------------------------------------
# 3. Cuan Insight Hosted Credential Control Plane
# -----------------------------------------------------------------------------
# Recommended when using Cuan Insight as the credential control plane.
CUAN_INSIGHT_API_BASE_URL=https://<your-cuan-insight-project>.supabase.co/functions/v1
CUAN_INSIGHT_CREDENTIAL_RESOLVE_PATH=/mcp-resolve-credential
CUAN_INSIGHT_SUPABASE_ANON_KEY=<your-supabase-anon-key>
CUAN_INSIGHT_REQUEST_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# 4. Auth Mode
# -----------------------------------------------------------------------------
# Auth modes:
# - connection_key: recommended for Cuan Insight (Section 5)
# - mcp_token: legacy/backward-compatible mode (Section 6)
CUAN_INSIGHT_AUTH_MODE=connection_key

# -----------------------------------------------------------------------------
# 5. Connection Key Mode
# -----------------------------------------------------------------------------
# LOCAL / SINGLE-TENANT ONLY:
# Use this when running stdio locally or a single-tenant self-hosted server.
# For hosted multi-user remote MCP, do NOT set a global connection key here.
# Instead, clients must send x-cuan-mcp-connection-key per request.
#
# Current v0.4.0 supports env-based Connection Key for local/single-tenant use.
# Per-request Connection Key passthrough for hosted multi-user is planned.
CUAN_INSIGHT_CONNECTION_KEY=<connection-key-from-cuan-insight-ui>

# -----------------------------------------------------------------------------
# 6. Legacy MCP Token Mode
# -----------------------------------------------------------------------------
# Legacy / backward-compatible mode.
# Use only when CUAN_INSIGHT_AUTH_MODE=mcp_token.
CUAN_INSIGHT_MCP_TOKEN=<legacy-mcp-token>
CUAN_INSIGHT_MCP_TOKEN_HEADER_NAME=X-Cuan-MCP-Token

# -----------------------------------------------------------------------------
# 7. OAuth Native Connector Flow (Phase 19)
# -----------------------------------------------------------------------------
# Required for native OAuth connector compatibility (Claude Desktop, Claude Code, etc.)
# Set the public base URL of your MCP server for OAuth redirects.
MCP_PUBLIC_BASE_URL=https://mcp.cuaninsight.com

# TTL for authorization codes in seconds (default: 300 = 5 min)
MCP_OAUTH_AUTH_CODE_TTL_SECONDS=300

# TTL for access tokens in seconds (default: 86400 = 24 hours)
MCP_OAUTH_ACCESS_TOKEN_TTL_SECONDS=86400

# -----------------------------------------------------------------------------
# 8. Self-Hosted Provider Token Mode
# -----------------------------------------------------------------------------
# Set BROKER_RUNTIME_MODE=local and fill in provider tokens below.
# Prefer Cuan Insight credential resolver unless you are extending the adapters yourself.
META_ACCESS_TOKEN=<your-meta-access-token>
TIKTOK_ACCESS_TOKEN=<your-tiktok-access-token>

# Optional test target placeholders.
CUAN_INSIGHT_TEST_PROVIDER=meta
CUAN_INSIGHT_TEST_ACCOUNT_ID=act_your_ad_account_id
