# Choose one runtime mode.
# Use remote for credential resolution through your hosted Cuan Insight-compatible broker.
# Use local for legacy direct Meta token usage.

# -----------------------------------------------------------------------------
# A. Remote credential mode
# -----------------------------------------------------------------------------
BROKER_RUNTIME_MODE=remote
CUAN_INSIGHT_API_BASE_URL=https://your-cuan-insight-domain/functions/v1
CUAN_INSIGHT_CREDENTIAL_RESOLVE_PATH=/mcp-resolve-credential
CUAN_INSIGHT_SUPABASE_ANON_KEY=your_supabase_anon_key
CUAN_INSIGHT_MCP_TOKEN=your_cuan_insight_mcp_token
CUAN_INSIGHT_MCP_TOKEN_HEADER_NAME=X-Cuan-MCP-Token

# Optional timeout in milliseconds.
CUAN_INSIGHT_REQUEST_TIMEOUT_MS=15000

# Optional test target placeholders.
CUAN_INSIGHT_TEST_PROVIDER=meta
CUAN_INSIGHT_TEST_ACCOUNT_ID=act_your_ad_account_id

# -----------------------------------------------------------------------------
# B. Local legacy mode
# -----------------------------------------------------------------------------
# BROKER_RUNTIME_MODE=local
# META_ACCESS_TOKEN=your_meta_access_token
# META_AD_ACCOUNT_ID=act_your_ad_account_id
# META_API_VERSION=v20.0

# Never commit .env.
# Never use a Supabase service role key here.
