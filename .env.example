# Runtime mode
BROKER_RUNTIME_MODE=remote

# Cuan Insight Staging Edge Function
CUAN_INSIGHT_API_BASE_URL=https://cdrpnkguwsffuihzrmmp.supabase.co/functions/v1
CUAN_INSIGHT_CREDENTIAL_RESOLVE_PATH=/mcp-resolve-credential

# Supabase Gateway Auth
# Ambil dari Supabase Staging Project → Settings → API → anon public key.
# Ini anon public key staging, bukan service role key.
# Jangan isi SUPABASE_SERVICE_ROLE_KEY.
CUAN_INSIGHT_SUPABASE_ANON_KEY=PASTE_STAGING_SUPABASE_ANON_KEY_HERE

# Cuan Insight MCP Token
# Isi dengan raw MCP token staging, BUKAN token_hash.
CUAN_INSIGHT_MCP_TOKEN=PASTE_STAGING_MCP_ACCESS_TOKEN_HERE

# Custom header untuk MCP token
CUAN_INSIGHT_MCP_TOKEN_HEADER_NAME=X-Cuan-MCP-Token

# Optional timeout
CUAN_INSIGHT_REQUEST_TIMEOUT_MS=15000

# Test target
CUAN_INSIGHT_TEST_PROVIDER=meta
CUAN_INSIGHT_TEST_ACCOUNT_ID=act_1417353822551653

# Local safety
# Jangan commit .env.
